---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const latestDemos = [
  {
    id: "7",
    title: "Rust OAuth2 Server",
    slug: "rust-oauth2-server",
    description: "A modern OAuth2/OIDC authorization server built in Rust with Actix-Web and the actor model, with first-class observability and Kubernetes-ready ops.",
    technologies: ["Rust", "OAuth2", "Actix"],
    liveUrl: "https://github.com/ianlintner/rust-oauth2-server",
  },
  {
    id: "6",
    title: "OAuth2 Proxy Sidecar",
    slug: "oauth2-sidecar",
    description: "Decentralized authentication for Kubernetes using the sidecar pattern. A production-ready solution with Helm charts, custom templates, and SSO support.",
    technologies: ["Kubernetes", "OAuth2", "Istio", "Helm"],
    liveUrl: "https://github.com/ianlintner/authproxy",
  },
  {
    id: "5",
    title: "Authentication Showcase",
    slug: "authentication-showcase",
    description: "A demo of major authentication methods in modern web applications with AI-enforced security best practices.",
    technologies: ["Next.js", "NextAuth.js", "OAuth"],
    liveUrl: "https://auth-demo.cat-herding.net",
  },
  {
    id: "4",
    title: "Audio Analysis and AI Review Utility in Rust",
    slug: "audio-ai-rust",
    description: "A command-line utility written in Rust for analyzing audio and providing AI-powered feedback for guitar practice sessions.",
    technologies: ["Rust", "FFmpeg", "AI"],
    liveUrl: "https://github.com/ianlintner/audio-ai",
  },
];
---

<Layout
  title="Ian Lintner - Engineering Leader & Platform Architect"
  description="Full stack software engineer portfolio featuring modern web development projects and technical blog posts."
>
  <div class="min-h-screen">
    {/* Hero Section */}
    <section class="relative overflow-hidden bg-gradient-to-br from-background via-primary/5 to-background py-20 sm:py-28">
      {/* Animated background elements */}
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl animate-pulse delay-1000"></div>
      </div>

      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12">
            {/* Trust badge */}
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary mb-6">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
              </span>
              <span class="text-sm font-medium">
                Available for exciting opportunities
              </span>
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
              <span class="block mb-2">Hi, I'm</span>
              <span class="bg-gradient-to-r from-primary via-primary to-primary/70 bg-clip-text text-transparent">
                Ian Lintner
              </span>
            </h1>

            <p class="text-2xl sm:text-3xl text-foreground mb-6 font-semibold">
              Engineering Leader & Platform Architect
            </p>

            <p class="text-lg sm:text-xl text-muted-foreground mb-8 max-w-3xl mx-auto leading-relaxed">
              Transforming complex challenges into elegant solutions with 20+
              years of experience. I architect secure, cloud-native platforms
              and mentor high-performing teams to deliver scalable,
              AI-augmented systems that drive real business value.
            </p>

            {/* Key value props */}
            <div class="flex flex-wrap justify-center gap-4 sm:gap-6 mb-10 text-sm sm:text-base">
              <div class="flex items-center gap-2 text-muted-foreground">
                <span class="font-bold text-primary text-xl">20+</span>
                <span>Years Experience</span>
              </div>
              <div class="hidden sm:block text-border">|</div>
              <div class="flex items-center gap-2 text-muted-foreground">
                <span class="font-bold text-primary text-xl">10+</span>
                <span>Cloud Technologies</span>
              </div>
              <div class="hidden sm:block text-border">|</div>
              <div class="flex items-center gap-2 text-muted-foreground">
                <span class="font-bold text-primary text-xl">∞</span>
                <span>Problems Solved</span>
              </div>
            </div>
          </div>

          {/* Primary CTAs */}
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-10">
            <a
              href="https://linkedin.com/in/ianlintner/"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center rounded-lg text-base font-semibold transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/30 hover:scale-105 h-14 px-10 w-full sm:w-auto"
            >
              <svg class="mr-2 h-5 w-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
              Let's Connect
              <svg class="ml-2 h-5 w-5 stroke-current fill-none group-hover:translate-x-1 transition-transform" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a
              href="/blog"
              class="group inline-flex items-center justify-center rounded-lg text-base font-semibold transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 border-2 border-primary/20 bg-background/50 backdrop-blur hover:bg-primary/10 hover:border-primary hover:shadow-lg h-14 px-10 w-full sm:w-auto"
            >
              Explore My Work
              <svg class="ml-2 h-5 w-5 stroke-current fill-none group-hover:translate-x-1 transition-transform" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>

          {/* Social proof / Contact links */}
          <div class="flex flex-col sm:flex-row justify-center items-center gap-6 pt-6">
            <p class="text-sm text-muted-foreground">Connect with me:</p>
            <div class="flex justify-center gap-4">
              <a
                href="https://github.com/ianlintner"
                target="_blank"
                rel="noopener noreferrer"
                class="p-3 rounded-full bg-card border border-border hover:border-primary hover:bg-primary/10 hover:shadow-lg transition-all duration-300 group"
                aria-label="GitHub"
              >
                <svg class="h-5 w-5 fill-current group-hover:text-primary group-hover:scale-110 transition-all" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              </a>
              <a
                href="https://www.linkedin.com/in/ianlintner/"
                target="_blank"
                rel="noopener noreferrer"
                class="p-3 rounded-full bg-card border border-border hover:border-primary hover:bg-primary/10 hover:shadow-lg transition-all duration-300 group"
                aria-label="LinkedIn"
              >
                <svg class="h-5 w-5 fill-current group-hover:text-primary group-hover:scale-110 transition-all" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </a>
              <a
                href="mailto:dev@codelintner.com"
                class="p-3 rounded-full bg-card border border-border hover:border-primary hover:bg-primary/10 hover:shadow-lg transition-all duration-300 group"
                aria-label="Email"
              >
                <svg class="h-5 w-5 fill-none stroke-current stroke-width-2 stroke-linecap="round" stroke-linejoin="round" group-hover:text-primary group-hover:scale-110 transition-all" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Trust Signals / Highlights Section */}
    <section class="py-16 border-y bg-gradient-to-b from-background to-accent/10">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="text-center p-6 rounded-xl bg-card border border-border hover:border-primary/30 hover:shadow-lg transition-all duration-300">
              <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="h-7 w-7 text-primary stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <circle cx="12" cy="8" r="7"></circle>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-primary mb-2">20+</h3>
              <p class="text-sm text-muted-foreground font-medium">
                Years of Experience
              </p>
            </div>

            <div class="text-center p-6 rounded-xl bg-card border border-border hover:border-primary/30 hover:shadow-lg transition-all duration-300">
              <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="h-7 w-7 text-primary stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-primary mb-2">10+</h3>
              <p class="text-sm text-muted-foreground font-medium">
                Technologies Mastered
              </p>
            </div>

            <div class="text-center p-6 rounded-xl bg-card border border-border hover:border-primary/30 hover:shadow-lg transition-all duration-300">
              <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="h-7 w-7 text-primary stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-primary mb-2">50+</h3>
              <p class="text-sm text-muted-foreground font-medium">
                Engineers Mentored
              </p>
            </div>

            <div class="text-center p-6 rounded-xl bg-card border border-border hover:border-primary/30 hover:shadow-lg transition-all duration-300">
              <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="h-7 w-7 text-primary stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-primary mb-2">100%</h3>
              <p class="text-sm text-muted-foreground font-medium">
                Commitment to Excellence
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Skills & Technologies Section */}
    <section class="py-24 bg-accent/20">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-3xl sm:text-4xl font-bold mb-4">
              Technologies & Expertise
            </h2>
            <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
              Specialized in modern development with a focus on performance,
              scalability, and delivering measurable business impact
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="group p-6 rounded-xl bg-card border border-border hover:border-primary hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="mb-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                  <span class="text-2xl">⚛️</span>
                </div>
                <h3 class="text-xl font-semibold mb-2">
                  Architecture & Platform
                </h3>
              </div>
              <ul class="space-y-1 text-muted-foreground text-sm">
                <li>• Event-driven systems & microservices</li>
                <li>• Secure APIs & LLM agent pipelines</li>
                <li>• System design & architecture diagrams</li>
                <li>• Cross-stack collaboration</li>
              </ul>
            </div>

            <div class="group p-6 rounded-xl bg-card border border-border hover:border-primary hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="mb-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                  <span class="text-2xl">🚀</span>
                </div>
                <h3 class="text-xl font-semibold mb-2">
                  Backend & Languages
                </h3>
              </div>
              <ul class="space-y-1 text-muted-foreground text-sm">
                <li>• Scala, Java, Python, C#, PHP</li>
                <li>• JavaScript, TypeScript, SQL</li>
                <li>• Akka, ZIO, gRPC, Kafka</li>
                <li>• Functional programming</li>
              </ul>
            </div>

            <div class="group p-6 rounded-xl bg-card border border-border hover:border-primary hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="mb-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                  <span class="text-2xl">☁️</span>
                </div>
                <h3 class="text-xl font-semibold mb-2">
                  Cloud & Infrastructure
                </h3>
              </div>
              <ul class="space-y-1 text-muted-foreground text-sm">
                <li>• AWS & Google Cloud (GCP)</li>
                <li>• Kubernetes, Terraform, Serverless</li>
                <li>• CI/CD, Flux, GitOps</li>
                <li>• Distributed observability</li>
              </ul>
            </div>

            <div class="group p-6 rounded-xl bg-card border border-border hover:border-primary hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="mb-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                  <span class="text-2xl">🔧</span>
                </div>
                <h3 class="text-xl font-semibold mb-2">
                  AI & Developer Workflow
                </h3>
              </div>
              <ul class="space-y-1 text-muted-foreground text-sm">
                <li>• Cline, Roo, GitHub Copilot</li>
                <li>• Feature Flags & Shadow Deploys</li>
                <li>• Observability & distributed tracing</li>
                <li>• Mentorship & design reviews</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* About Section */}
    <section class="py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl sm:text-4xl font-bold mb-4">About Me</h2>
            <div class="w-20 h-1 bg-primary mx-auto rounded-full mb-8"></div>
          </div>

          <div class="prose prose-lg dark:prose-invert max-w-none">
            <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
              <p class="text-xl text-foreground font-medium">
                I'm an engineering leader and platform architect
                passionate about building secure, scalable systems that
                empower teams and accelerate innovation.
              </p>
              <p>
                My career spans over two decades across startups and
                enterprise environments, where I've led backend
                transformations, architected event-driven systems, and
                integrated AI into production workflows. At Carvana, I
                spearheaded the backend rewrite of the AI communications
                platform—improving orchestration between LLMs and human
                agents, and driving adoption of AI-assisted engineering tools.
              </p>
              <p>
                My technical foundation includes Scala, Python, and
                cloud-native infrastructure (GCP, AWS, Kubernetes, Terraform).
                I'm deeply invested in developer experience,
                observability, and reliability—ensuring systems are not only
                performant but maintainable and transparent.
              </p>
              <p class="text-foreground font-medium">
                I also mentor engineers and advocate for AI-augmented
                development practices that enhance creativity and
                productivity.
              </p>
            </div>
          </div>

          <div class="mt-10 text-center">
            <a
              href="/blog"
              class="inline-flex items-center text-primary hover:text-primary/80 font-medium text-lg group"
            >
              Read more about my journey
              <svg class="ml-2 h-5 w-5 stroke-current fill-none group-hover:translate-x-1 transition-transform" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Latest Blog Posts Section */}
    {latestPosts.length > 0 && (
      <section class="py-24 bg-accent/20">
        <div class="container mx-auto px-4">
          <div class="max-w-6xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl sm:text-4xl font-bold mb-4">
                Latest Articles
              </h2>
              <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
                Recent insights on software architecture, cloud platforms, and
                AI-driven development
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
              {latestPosts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="group bg-card border border-border rounded-xl p-6 hover:shadow-xl hover:border-primary/20 transition-all duration-300 hover:-translate-y-1"
                >
                  <div class="flex items-center gap-3 text-sm text-muted-foreground mb-4">
                    <div class="flex items-center gap-1">
                      <svg class="h-4 w-4 stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                      </svg>
                      <span>
                        {new Date(post.data.date).toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "short",
                          day: "numeric",
                        })}
                      </span>
                    </div>
                    <div class="flex items-center gap-1">
                      <svg class="h-4 w-4 stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      <span>5 min</span>
                    </div>
                  </div>

                  <h3 class="text-xl font-semibold mb-3 group-hover:text-primary transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>

                  <p class="text-muted-foreground leading-relaxed line-clamp-3 mb-4">
                    {post.data.excerpt}
                  </p>

                  <div class="inline-flex items-center text-primary font-medium text-sm group/link">
                    Read More
                    <svg class="ml-1 h-4 w-4 stroke-current fill-none group-hover/link:translate-x-1 transition-transform" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </div>
                </a>
              ))}
            </div>

            <div class="text-center">
              <a
                href="/blog"
                class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold border-2 border-primary/30 bg-background hover:bg-primary/10 hover:border-primary rounded-lg transition-all duration-300"
              >
                View All Articles
                <svg class="ml-2 h-5 w-5 stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </div>
