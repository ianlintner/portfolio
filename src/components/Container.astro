---
import { cn } from '../utils/cn';

interface Props {
  maxWidth?: "sm" | "md" | "lg" | "xl" | "2xl" | "full";
  padded?: boolean;
  center?: boolean;
  class?: string;
  id?: string;
  [key: string]: any;
}

const {
  maxWidth = "xl",
  padded = true,
  center = true,
  class: className,
  id,
  ...props
} = Astro.props;

const widthClasses = {
  sm: "max-w-screen-sm",
  md: "max-w-screen-md",
  lg: "max-w-screen-lg",
  xl: "max-w-screen-xl",
  "2xl": "max-w-screen-2xl",
  full: "max-w-full",
};
---

<div
  class={cn(
    "w-full",
    widthClasses[maxWidth],
    padded && "px-4 sm:px-6 lg:px-8",
    center && "mx-auto",
    className,
  )}
  id={id}
  {...props}
>
  <slot />
</div>
