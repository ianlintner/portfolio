---
import { cn } from '../utils/cn';

interface Props {
  orientation?: "horizontal" | "vertical";
  label?: string;
  variant?: "muted" | "strong" | "glow";
  class?: string;
  id?: string;
  [key: string]: any;
}

const {
  orientation = "horizontal",
  label,
  variant = "muted",
  class: className,
  id,
  ...props
} = Astro.props;

const baseLine = "flex-1 bg-border/70";
const variantMap = {
  muted: baseLine,
  strong: "flex-1 bg-foreground/40",
  glow: "flex-1 bg-gradient-to-r from-primary/50 via-accent/50 to-primary/50 blur-[0.2px]",
};
---

{
  orientation === "vertical" ? (
    <div
      role="separator"
      aria-orientation="vertical"
      class={cn(
        "flex h-full flex-col items-center",
        label || Astro.slots.has('default') ? "gap-2 px-2" : "px-1",
        className,
      )}
      id={id}
      {...props}
    >
      <span class={cn("w-px flex-1", variantMap[variant])} />
      {(label || Astro.slots.has('default')) && (
        <span class="text-xs font-medium text-muted-foreground">
          {label || <slot />}
        </span>
      )}
      <span class={cn("w-px flex-1", variantMap[variant])} />
    </div>
  ) : (
    <div
      role="separator"
      aria-orientation="horizontal"
      class={cn(
        "flex w-full items-center",
        label || Astro.slots.has('default') ? "gap-3" : "gap-2",
        className,
      )}
      id={id}
      {...props}
    >
      <span class={cn("h-px", variantMap[variant])} />
      {(label || Astro.slots.has('default')) && (
        <span class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
          {label || <slot />}
        </span>
      )}
      <span class={cn("h-px", variantMap[variant])} />
    </div>
  )
}
