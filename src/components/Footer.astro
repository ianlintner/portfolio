---
import Container from './Container.astro';
import Section from './Section.astro';
import Grid from './Grid.astro';
import Divider from './Divider.astro';

const year = new Date().getFullYear();
---

<footer class="border-t bg-gradient-to-b from-background to-accent/10 transition-colors">
  <Container>
    <Section class="py-12">
      {/* Main Footer Content */}
      <Grid cols={{ base: 1, md: 4 }} gap={8} class="mb-8">
        {/* About */}
        <div class="md:col-span-2">
          <h3 class="font-bold text-lg mb-4 bg-gradient-to-r from-primary to-primary/70 bg-clip-text text-transparent">
            Ian Lintner
          </h3>
          <p class="text-sm text-muted-foreground mb-4 leading-relaxed">
            Engineering leader and platform architect with 20+ years of
            experience building secure, scalable systems. Passionate about
            mentoring teams and integrating AI into modern workflows.
          </p>
          <div class="flex gap-3">
            <a
              href="https://github.com/ianlintner"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center font-medium transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background border border-border bg-transparent text-foreground hover:bg-accent/10 hover:border-accent active:bg-accent/20 focus-visible:ring-accent h-8 px-3 text-sm gap-1.5 rounded-md"
              aria-label="GitHub"
              title="GitHub"
            >
              <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            </a>
            <a
              href="https://linkedin.com/in/ianlintner/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center font-medium transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background border border-border bg-transparent text-foreground hover:bg-accent/10 hover:border-accent active:bg-accent/20 focus-visible:ring-accent h-8 px-3 text-sm gap-1.5 rounded-md"
              aria-label="LinkedIn"
              title="LinkedIn"
            >
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </a>
            <a
              href="mailto:dev@codelintner.com"
              class="inline-flex items-center justify-center font-medium transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background border border-border bg-transparent text-foreground hover:bg-accent/10 hover:border-accent active:bg-accent/20 focus-visible:ring-accent h-8 px-3 text-sm gap-1.5 rounded-md"
              aria-label="Email"
              title="Email"
            >
              <svg class="h-5 w-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </a>
          </div>
        </div>

        {/* Quick Links */}
        <div>
          <h3 class="font-semibold mb-4">Navigate</h3>
          <ul class="space-y-2.5 text-sm">
            <li>
              <a
                href="/"
                class="text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1 group"
              >
                <span class="group-hover:translate-x-1 transition-transform inline-block">
                  →
                </span>
                Home
              </a>
            </li>
            <li>
              <a
                href="/resume"
                class="text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1 group"
              >
                <span class="group-hover:translate-x-1 transition-transform inline-block">
                  →
                </span>
                Resume
              </a>
            </li>
            <li>
              <a
                href="/blog"
                class="text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1 group"
              >
                <span class="group-hover:translate-x-1 transition-transform inline-block">
                  →
                </span>
                Blog
              </a>
            </li>
            <li>
              <a
                href="/demos"
                class="text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1 group"
              >
                <span class="group-hover:translate-x-1 transition-transform inline-block">
                  →
                </span>
                Projects
              </a>
            </li>
            <li>
              <a
                href="/about"
                class="text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1 group"
              >
                <span class="group-hover:translate-x-1 transition-transform inline-block">
                  →
                </span>
                About & Support
              </a>
            </li>
          </ul>
        </div>

        {/* Specializations */}
        <div>
          <h3 class="font-semibold mb-4">Specializations</h3>
          <ul class="space-y-2.5 text-sm text-muted-foreground">
            <li>• Platform Architecture</li>
            <li>• Cloud Infrastructure</li>
            <li>• AI Integration</li>
            <li>• Team Leadership</li>
            <li>• System Design</li>
          </ul>
        </div>
      </Grid>

      {/* Bottom Bar */}
      <Divider class="my-8" />
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-muted-foreground">
        <p>
          &copy; {year} Ian Lintner / Lintner Consulting LLC. Built with Astro, HTMX, and ❤️
        </p>
        <div class="flex gap-6">
          <a
            href="/privacy"
            class="hover:text-primary transition-colors"
          >
            Privacy
          </a>
          <a
            href="/terms"
            class="hover:text-primary transition-colors"
          >
            Terms
          </a>
          <a
            href="https://github.com/ianlintner/portfolio"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors"
          >
            View Source
          </a>
        </div>
      </div>
    </Section>
  </Container>

  {/* Simple 64x64 sprite cats (decorative; hidden for print/reduced motion) */}
  <div
    aria-hidden="true"
    class="footer-sprite-cats print:hidden"
  >
    <div class="footer-sprite-cats__ground" />

    <div class="footer-sprite-cats__cat footer-sprite-cats__cat--l2r">
      <span
        aria-hidden="true"
        data-cat="1"
        data-action="walk"
        data-dir="right"
        data-animated="true"
        class="footer-sprite-cats__sprite"
      />
    </div>

    <div class="footer-sprite-cats__cat footer-sprite-cats__cat--r2l">
      <span
        aria-hidden="true"
        data-cat="2"
        data-action="walk"
        data-dir="left"
        data-animated="true"
        class="footer-sprite-cats__sprite"
      />
    </div>
  </div>
</footer>
