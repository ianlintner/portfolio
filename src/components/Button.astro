---
import { cn } from '../utils/cn';

interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost" | "destructive" | "glass";
  size?: "xs" | "sm" | "md" | "lg" | "xl";
  glow?: boolean;
  loading?: boolean;
  fullWidth?: boolean;
  class?: string;
  href?: string;
  id?: string;
  [key: string]: any;
}

const {
  variant = "primary",
  size = "md",
  glow = false,
  loading = false,
  fullWidth = false,
  class: className,
  href,
  id,
  ...props
} = Astro.props;

const variantStyles = {
  primary: "bg-primary text-primary-foreground hover:bg-primary/90 active:bg-primary/80 focus-visible:ring-primary",
  secondary: "bg-secondary text-secondary-foreground hover:bg-secondary/80 active:bg-secondary/70 focus-visible:ring-secondary",
  outline: "border border-border bg-transparent text-foreground hover:bg-accent/10 hover:border-accent active:bg-accent/20 focus-visible:ring-accent",
  ghost: "bg-transparent text-foreground hover:bg-accent/10 active:bg-accent/20 focus-visible:ring-accent",
  destructive: "bg-destructive text-destructive-foreground hover:bg-destructive/90 active:bg-destructive/80 focus-visible:ring-destructive",
  glass: "glass text-foreground hover:glass-elevated active:bg-glass-dark/60 focus-visible:ring-primary",
};

const sizeStyles = {
  xs: "h-7 px-2 text-xs gap-1 rounded [&_svg]:w-3 [&_svg]:h-3",
  sm: "h-8 px-3 text-sm gap-1.5 rounded-md [&_svg]:w-4 [&_svg]:h-4",
  md: "h-10 px-4 text-sm gap-2 rounded-lg [&_svg]:w-4 [&_svg]:h-4",
  lg: "h-11 px-6 text-base gap-2 rounded-lg [&_svg]:w-5 [&_svg]:h-5",
  xl: "h-12 px-8 text-lg gap-3 rounded-xl [&_svg]:w-6 [&_svg]:h-6",
};

const classes = cn(
  "inline-flex items-center justify-center font-medium transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background",
  variantStyles[variant],
  sizeStyles[size],
  glow && "hover:shadow-glow",
  fullWidth && "w-full",
  (props.disabled || loading) && "opacity-50 cursor-not-allowed pointer-events-none",
  className
);
---

{
  href ? (
    <a href={href} class={classes} id={id} {...props}>
      <slot name="left-icon" />
      <slot />
      <slot name="right-icon" />
    </a>
  ) : (
    <button class={classes} id={id} disabled={props.disabled || loading} {...props}>
      {loading && (
        <svg class="animate-spin -ml-1 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      )}
      {!loading && <slot name="left-icon" />}
      <slot />
      {!loading && <slot name="right-icon" />}
    </button>
  )
}
