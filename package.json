{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm docs:build && astro build",
    "build:static": "pnpm docs:build && astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "test:ci": "jest --ci --passWithNoTests",
    "test:e2e": "playwright test",
    "docs:build": "python3 -m mkdocs build -d public/docs",
    "docs:serve": "python3 -m mkdocs serve"
  },
  "dependencies": {
    "@tailwindcss/typography": "latest",
    "autoprefixer": "^10.4.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.2",
    "htmx.org": "^1.9.12",
    "phaser": "^3.90.0",
    "postcss": "^8.4.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.0",
    "mermaid": "^10.9.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@astrojs/mdx": "^3.1.5",
    "@astrojs/tailwind": "^5.1.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "latest",
    "astro": "^4.15.0",
    "eslint": "latest",
    "prettier": "latest",
    "remark-math": "^6.0.0",
    "rehype-katex": "^7.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "latest"
  }
}
